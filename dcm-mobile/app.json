{
  "expo": {
    "name": "DCM Grading",
    "slug": "dcm-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dcmgrading",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dcmgrading.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "DCM Grading needs camera access to photograph your trading cards for AI-powered professional grading.",
        "NSPhotoLibraryUsageDescription": "DCM Grading needs access to your photo library so you can upload existing card photos for grading.",
        "NSPhotoLibraryAddOnlyUsageDescription": "DCM Grading needs permission to save downloaded labels and graded card images to your photos."
      }
    },
    "android": {
      "package": "com.dcmgrading.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      ["expo-router", { "root": "./app" }],
      "expo-secure-store",
      "expo-web-browser",
      ["@stripe/stripe-react-native", { "merchantIdentifier": "merchant.com.dcmgrading" }]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
